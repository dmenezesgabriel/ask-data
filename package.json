{
  "name": "portable-bi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --cache && stylelint 'src/**/*.css'",
    "lint:fix": "eslint src tests --fix && stylelint 'src/**/*.css' --fix",
    "lint:staged": "lint-staged --concurrent false",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview --host 0.0.0.0",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit",
    "test:unit:serial": "npm run test:unit",
    "test:components": "vitest run --project components",
    "test:storybook": "vitest run --project storybook",
    "test:integration": "node --import tsx/esm --loader ./tests/helpers/yaml-loader.mjs node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/integration/features/**/*.feature' --import 'tests/integration/steps/**/*.ts' --format progress --force-exit",
    "test:e2e": "node --import tsx/esm --loader ./tests/helpers/yaml-loader.mjs node_modules/@cucumber/cucumber/bin/cucumber.js 'tests/e2e/features/**/*.feature' --import 'tests/e2e/steps/**/*.ts' --format progress --force-exit",
    "test": "npm run test:unit && npm run test:components && npm run test:storybook && npm run test:integration && npm run test:e2e",
    "test:serial": "npm run test",
    "test:hooks": "npm run test:unit && npm run test:components && npm run test:storybook",
    "test:mutation": "stryker run",
    "duplication:check": "jscpd src",
    "knip": "knip",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@duckdb/duckdb-wasm": "1.30.0",
    "@huggingface/transformers": "4.0.1",
    "chart.js": "^4.4.9",
    "chrono-node": "2.7.7",
    "fuse.js": "7.0.0",
    "lit": "3.1.0",
    "lucide": "^1.14.0",
    "minisearch": "7.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@cucumber/cucumber": "^12.8.2",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/web-components-vite": "^10.4.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.2",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "apache-arrow": "^17.0.0",
    "duckdb": "^1.4.4",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "^10.4.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.4",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.4",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
